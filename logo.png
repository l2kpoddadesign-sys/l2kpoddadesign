<!DOCTYPE html>
<html>
<head>
<title>L2K & PODDA CREATIONS</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Poppins, sans-serif;}
body{color:white;text-align:center;background:linear-gradient(-45deg,#0f2027,#203a43,#2c5364,#000000);background-size:400% 400%;animation:bg 10s infinite alternate;overflow-x:hidden;}
@keyframes bg{0%{background-position:left}100%{background-position:right}}
header{padding:40px 20px;position:sticky;top:0;z-index:1000;background:rgba(0,0,0,0.6);backdrop-filter:blur(5px);}
.logo{width:200px;animation:float 3s infinite ease-in-out;margin:0 auto;display:block;}
@keyframes float{0%{transform:translateY(0)}50%{transform:translateY(-10px)}100%{transform:translateY(0)}}
.hero{padding:60px 20px;position:relative;}
.hero h1{font-size:42px;margin-bottom:10px;color:#FFD1D1;}
.hero p{color:#FFCCCC;margin-bottom:25px;font-size:18px;}
.btn{background:#00ffd5;border:none;padding:15px 35px;font-size:18px;border-radius:30px;cursor:pointer;transition:0.3s;}
.btn:hover{background:white;color:black;transform:scale(1.1);}
.services{padding:60px 20px;}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:25px;margin-top:30px;}
.card{background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);padding:30px;border-radius:15px;transition:0.5s;cursor:pointer;}
.card:hover{transform:translateY(-12px) scale(1.05);background:rgba(255,255,255,0.2);}
.portfolio{padding:60px 20px;}
.gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-top:25px;}
.gallery img{width:100%;border-radius:12px;transition:0.4s;cursor:pointer;}
.gallery img:hover{transform:scale(1.1);box-shadow:0 0 15px #00ffd5;}
footer{margin-top:40px;padding:30px;background:rgba(0,0,0,0.5);}
.whatsapp{position:fixed;bottom:20px;right:20px;background:#25D366;padding:16px;border-radius:50%;font-size:22px;color:white;text-decoration:none;box-shadow:0 0 15px #25D366;transition:0.3s;}
.whatsapp:hover{transform:scale(1.2);}
.section{opacity:0;transform:translateY(30px);transition:0.6s;}
.section.visible{opacity:1;transform:translateY(0);}
form{display:flex;flex-direction:column;gap:15px;margin-top:20px;}
input,textarea{padding:12px;border-radius:10px;border:none;outline:none;}
input[type="submit"]{background:#00ffd5;color:black;cursor:pointer;font-weight:bold;transition:0.3s;}
input[type="submit"]:hover{background:white;transform:scale(1.05);}
.snowflake{position:absolute;top:-10px;color:white;font-size:1em;user-select:none;pointer-events:none;animation:fall linear infinite;}
@keyframes fall{0%{transform:translateY(0) rotate(0deg);}100%{transform:translateY(100vh) rotate(360deg);}}
</style>
</head>

<body>

<header>
<!-- Logo added -->
<img src="logo.png" class="logo">
</header>

<section class="hero section">
<h1>L2K & PODDA CREATIONS</h1>
<p>Creative | Professional | Trusted Graphics Design Services</p>
<a href="https://wa.me/94740682507"><button class="btn">Contact on WhatsApp</button></a>
<!-- Snow container -->
<div id="snow-container"></div>
</section>

<section class="services section">
<h2>Our Services</h2>
<div class="grid">
<div class="card">🎨 Logo Design</div>
<div class="card">📱 Social Media Post Design</div>
<div class="card">🖼️ YouTube Thumbnail</div>
<div class="card">📢 Advertisement Posters</div>
<div class="card">📘 Facebook / TikTok Covers</div>
</div>
</section>

<section class="portfolio section">
<h2>Our Designs</h2>
<div class="gallery">
<img src="https://via.placeholder.com/400">
<img src="https://via.placeholder.com/400">
<img src="https://via.placeholder.com/400">
</div>
</section>

<section class="order section">
<h2>Place Your Order</h2>
<form action="https://wa.me/94740682507" method="get" target="_blank">
<input type="text" name="text" placeholder="Your Name" required>
<input type="text" name="text" placeholder="Service Required" required>
<input type="text" name="text" placeholder="Your Details / Notes" required>
<input type="submit" value="Send Order via WhatsApp">
</form>
</section>

<footer class="section">
<p>📱 0740682507</p>
<p>📱 0722637889</p>
<p>© 2026 L2K & PODDA CREATIONS</p>
</footer>

<a class="whatsapp" href="https://wa.me/94740682507">💬</a>

<script>
// Scroll animation
const sections = document.querySelectorAll('.section');
window.addEventListener('scroll', () => {
sections.forEach(section => {
if(section.getBoundingClientRect().top < window.innerHeight - 100){
section.classList.add('visible');
}
});
});

// Snow effect
const snowContainer = document.getElementById('snow-container');
const snowCount = 40;
for(let i=0;i<snowCount;i++){
const snow = document.createElement('div');
snow.className='snowflake';
snow.innerHTML='❄';
snow.style.left=Math.random()*100+'%';
snow.style.fontSize=(10+Math.random()*15)+'px';
snow.style.animationDuration=(5+Math.random()*10)+'s';
snow.style.opacity=Math.random();
snowContainer.appendChild(snow);
}
</script>

</body>
</html>